{
  "name": "jianli-extension",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest --verbose",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "addons-linter": "^10.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "./tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "transform": {}
  }
}
